# ============================================================
# RAX3000M OpenWrt 编译配置 - 完整版
# 目标: 中移 RAX3000M (MT7981B / Filogic 820)
# 配置: 512MB RAM, WiFi6 AX3000
#
# 硬件与刷机（与机身标签对应）:
# - NAND 版：标签为「CH  CMIIT ID」（EC 位置为空）→ 日常升级用 *squashfs*sysupgrade*.itb；
#   裸写 Preloader/FIP 时只能用 *nand-ddr3-* 或 *nand-ddr4-*（与内存一致），禁止 *emmc-*。
# - eMMC 算力版：标签含「CH EC CMIIT ID」→ 裸写只能用 *emmc-* 的 preloader+fip；禁止与 NAND 混用。
#
# 上游 cmcc_rax3000m 为单一目标：sysupgrade.itb / recovery.itb 对 NAND 与 eMMC 共用一套产物；
# Preloader/FIP 在 bin/targets/... 下会同时生成两套，按硬件各取所需，不可混刷。
# ============================================================

# ==================== 目标平台 ====================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cmcc_rax3000m=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_redmi-router-ax6s=n

# ==================== 镜像配置 ====================
# 生成 *-initramfs-recovery.itb：内核+内存中的 rootfs，重启不保留 overlay（开发/救砖/TFTP），不是独立的 kernel.bin
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_PARTITIONS=y
CONFIG_TARGET_IMAGE_PARTSIZE=500
# ROOTFS_PARTNAME 仅在使用 GRUB 镜像时生效；Filogic 不走 GRUB，勿填 mmcblk 以免误以为 eMMC 专用
CONFIG_TARGET_ROOTFS_MAXINODE=60000
CONFIG_TARGET_ROOTFS_INCLUDE_ZLIB=y
CONFIG_TARGET_ROOTFS_INCLUDE_LIBTIRPC=y

# ==================== 内核配置 ====================
CONFIG_KERNEL_GIT_CLONE_URI=""
CONFIG_KERNEL_BUILD_DOMAIN="ARX3000M"
CONFIG_KERNEL_BUILD_USER="Custom Build"

